# Example environment variables for local development
# Do not commit your actual .env or .env.local files.

# Backend server
PORT=3000
MONGO_URI=mongodb://user:password@localhost:27017/smmsecure
JWT_ACCESS_TOKEN_SECRET=your-secret-key
JWT_REFRESH_TOKEN_SECRET=your-refresh-secret
CLIENT_ORIGIN=http://localhost:5174
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174

# Vite frontend API URL
# Production (deployed backend):
VITE_API_URL=https://smmneo-server.vercel.app
# Local development (uncomment to use local backend):
# VITE_API_URL=http://localhost:3000
